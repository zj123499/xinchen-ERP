# 数据库连接（PostgreSQL）
DATABASE_URL="postgres://用户名:密码@主机:端口/数据库名?sslmode=disable"

# JWT 密钥（生产环境务必修改为随机字符串）
JWT_SECRET="change-me-to-a-random-secret-string"
NEXTAUTH_SECRET="change-me-to-another-random-secret"

# 应用 URL
NEXTAUTH_URL="http://localhost:3000"

# 钉钉应用配置（可选）
# DINGTALK_APP_KEY=""
# DINGTALK_APP_SECRET=""
