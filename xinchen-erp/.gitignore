.env
.env.local
.env.development.local
.env.test.local
.env.*.local
!.env.production
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# build artifacts
/.next/
/out/
/.swc/

# legacy deploy debug scripts (expect)
*.exp

# OS
.DS_Store

/src/generated/prisma
