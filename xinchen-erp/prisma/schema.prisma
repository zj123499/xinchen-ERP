  name           String        @db.VarChar(200)
  description    Json?
  price          Decimal       @db.Decimal(12, 2)
  commissionRate Decimal?      @map("commission_rate") @db.Decimal(5, 2)
  status         ProductStatus @default(ACTIVE)
  remark         String?       @db.Text
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  businessLine   BusinessLine?    @relation(fields: [businessLineId], references: [id])
  country        Country?         @relation(fields: [countryId], references: [id])
  institution    Institution?     @relation(fields: [institutionId], references: [id])
  childPackages  ProductPackage[] @relation("ProductChildren")
  parentPackages ProductPackage[] @relation("ProductParents")

  @@index([tenantId])
  @@map("products")
}

model ProductPackage {
  id              Int      @id @default(autoincrement())
  tenantId        Int      @map("tenant_id")
  parentProductId Int      @map("parent_product_id")
  childProductId  Int      @map("child_product_id")
  discount        Decimal? @db.Decimal(5, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  parentProduct Product? @relation("ProductParents", fields: [parentProductId], references: [id], map: "pkg_parent_fkey")
  childProduct  Product? @relation("ProductChildren", fields: [childProductId], references: [id], map: "pkg_child_fkey")

  @@index([tenantId])
  @@map("product_packages")
}

// ============================================================
// 安全策略（行为熔断规则，谷歌2.0 新增）
// ============================================================

model SecurityPolicy {
  id            Int      @id @default(autoincrement())
  tenantId      Int      @map("tenant_id")
  name          String   @db.VarChar(100)
  // export_limit: 1小时内最大导出条数； view_limit: 1天内最大查看条数
  metric        String   @db.VarChar(50) // EXPORT_COUNT / VIEW_CONTACT_COUNT
  threshold     Int
  windowMinutes Int      @map("window_minutes")
  action        String   @default("WARN") @db.VarChar(20) // WARN / LOCK
  notifyRole    String?  @map("notify_role") @db.VarChar(50)
  enabled       Boolean  @default(true)
  remark        String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("security_policies")
}

// ============================================================
// 审批流引擎（P4.5 新增，独立于工作流）
// ============================================================

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  TRANSFERRED
  CANCELLED
}

enum ApprovalNodeType {
  APPROVE
  CC
  TRANSFER
}

enum ApprovalSignMode {
  AND // 会签：全部通过
  OR // 或签：任一通过
}

model ApprovalFlow {
  id           Int              @id @default(autoincrement())
  tenantId     Int              @map("tenant_id")
  name         String           @db.VarChar(100)
  // 业务类型：CONTRACT_DISCOUNT / REFUND / REIMBURSEMENT / LEAD_TRANSFER
  businessType String           @map("business_type") @db.VarChar(50)
  description  String?          @db.Text
  signMode     ApprovalSignMode @default(AND) @map("sign_mode")
  enabled      Boolean          @default(true)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  tenant  Tenant           @relation(fields: [tenantId], references: [id])
  nodes   ApprovalNode[]
  records ApprovalRecord[]

  @@unique([tenantId, businessType])
  @@index([tenantId])
  @@map("approval_flows")
}

model ApprovalNode {
  id            Int              @id @default(autoincrement())
  flowId        Int              @map("flow_id")
  nodeType      ApprovalNodeType @default(APPROVE)
  orderNo       Int              @map("order_no")
  name          String           @db.VarChar(100)
  approverRole  String?          @map("approver_role") @db.VarChar(50)
  approverId    Int?             @map("approver_id")
  conditionExpr String?          @map("condition_expr") @db.Text
  createdAt     DateTime         @default(now()) @map("created_at")

  flow    ApprovalFlow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  records ApprovalRecord[]

  @@index([flowId])
  @@map("approval_nodes")
}

model ApprovalRecord {
  id               Int            @id @default(autoincrement())
  tenantId         Int            @map("tenant_id")
  flowId           Int            @map("flow_id")
  nodeId           Int            @map("node_id")
  businessType     String         @map("business_type") @db.VarChar(50)
  businessId       Int            @map("business_id")
  applicantId      Int            @map("applicant_id")
  approverId       Int?           @map("approver_id")
  status           ApprovalStatus @default(PENDING)
  comment          String?        @db.Text
  attachments      Json?
  currentNodeOrder Int            @default(1) @map("current_node_order")
  submittedAt      DateTime       @default(now()) @map("submitted_at")
  decidedAt        DateTime?      @map("decided_at")

  tenant Tenant       @relation(fields: [tenantId], references: [id])
  flow   ApprovalFlow @relation(fields: [flowId], references: [id])
  node   ApprovalNode @relation(fields: [nodeId], references: [id])

  @@index([tenantId])
  @@index([businessType, businessId])
  @@index([approverId, status])
  @@map("approval_records")
}

// ============================================================
// 客户成功中心（P6 新增）
// ============================================================

enum SurveyStatus {
  SENT
  RESPONDED
  EXPIRED
}

enum VisitResult {
  NORMAL
  RISK
  COMPLAINT
  REFERRAL_INTENT
}

enum ComplaintStatus {
  OPEN
  PROCESSING
  RESOLVED
  CLOSED
}

enum ReferralStatus {
  PENDING
  CONVERTED
  REWARDED
  INVALID
}

model SatisfactionSurvey {
  id              Int          @id @default(autoincrement())
  tenantId        Int          @map("tenant_id")
  studentId       Int          @map("student_id")
  nps             Int? // 0-10 净推荐值
  score           Int? // 总体评分 0-5
  dimensionScores Json?        @map("dimension_scores")
  feedback        String?      @db.Text
  status          SurveyStatus @default(SENT)
  sentAt          DateTime     @default(now()) @map("sent_at")
  respondedAt     DateTime?    @map("responded_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("satisfaction_surveys")
}

model ServiceVisit {
  id        Int         @id @default(autoincrement())
  tenantId  Int         @map("tenant_id")
  studentId Int         @map("student_id")
  visitorId Int         @map("visitor_id")
  visitDate DateTime    @map("visit_date")
  channel   String?     @db.VarChar(50) // PHONE / WECHAT / VISIT / VIDEO
  result    VisitResult @default(NORMAL)
  summary   String?     @db.Text
  nextPlan  String?     @map("next_plan") @db.Text
  createdAt DateTime    @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("service_visits")
}

model Complaint {
  id         Int             @id @default(autoincrement())
  tenantId   Int             @map("tenant_id")
  studentId  Int             @map("student_id")
  title      String          @db.VarChar(200)
  content    String?         @db.Text
  level      Int             @default(2) // 1 高 / 2 中 / 3 低
  status     ComplaintStatus @default(OPEN)
  handlerId  Int?            @map("handler_id")
  resolvedAt DateTime?       @map("resolved_at")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("complaints")
}

model Referral {
  id           Int            @id @default(autoincrement())
  tenantId     Int            @map("tenant_id")
  referrerId   Int            @map("referrer_id") // 推荐人（学生）
  refereeName  String         @map("referee_name") @db.VarChar(100)
  refereePhone String?        @map("referee_phone") @db.VarChar(50)
  newStudentId Int?           @map("new_student_id")
  rewardType   String?        @map("reward_type") @db.VarChar(50) // CASH / COUPON / UPGRADE
  rewardAmount Decimal?       @map("reward_amount") @db.Decimal(10, 2)
  status       ReferralStatus @default(PENDING)
  remark       String?        @db.Text
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  referrer   Student  @relation("ReferralsByStudent", fields: [referrerId], references: [id], onDelete: Cascade)
  newStudent Student? @relation("ReferralNewStudent", fields: [newStudentId], references: [id])

  @@index([tenantId])
  @@map("referrals")
}

// ============================================================
// 风险管理中心（P7 新增）
// ============================================================

enum RiskLevel {
  HIGH
  MEDIUM
  LOW
}

enum RiskRecordStatus {
  OPEN
  RESOLVED
  IGNORED
}

model RiskRule {
  id            Int       @id @default(autoincrement())
  tenantId      Int       @map("tenant_id")
  name          String    @db.VarChar(100)
  description   String?   @db.Text
  // 规则表达式，由风险扫描引擎解析，例如：
  // daysToDeadline < 7 AND materialCompletion < 0.8
  conditionExpr String    @map("condition_expr") @db.Text
  riskLevel     RiskLevel @default(MEDIUM) @map("risk_level")
  notifyRoles   String?   @map("notify_roles") @db.VarChar(200)
  enabled       Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant  Tenant       @relation(fields: [tenantId], references: [id])
  records RiskRecord[]

  @@index([tenantId])
  @@map("risk_rules")
}

model RiskRecord {
  id         Int              @id @default(autoincrement())
  tenantId   Int              @map("tenant_id")
  ruleId     Int              @map("rule_id")
  studentId  Int?             @map("student_id")
  riskLevel  RiskLevel        @default(MEDIUM) @map("risk_level")
  status     RiskRecordStatus @default(OPEN)
  detail     String?          @db.Text
  detectedAt DateTime         @default(now()) @map("detected_at")
  resolvedAt DateTime?        @map("resolved_at")
  resolvedBy Int?             @map("resolved_by")
  createdAt  DateTime         @default(now()) @map("created_at")

  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  rule          RiskRule           @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  student       Student?           @relation(fields: [studentId], references: [id], onDelete: SetNull)
  notifications RiskNotification[]

  @@index([tenantId, status])
  @@map("risk_records")
}

model RiskNotification {
  id           Int      @id @default(autoincrement())
  tenantId     Int      @map("tenant_id")
  riskRecordId Int      @map("risk_record_id")
  studentId    Int?     @map("student_id")
  channel      String   @db.VarChar(20) // DINGTALK / EMAIL / SYSTEM
  content      String   @db.Text
  sentAt       DateTime @default(now()) @map("sent_at")
  read         Boolean  @default(false)

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  riskRecord RiskRecord @relation(fields: [riskRecordId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("risk_notifications")
}
