generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  DEAD
}

enum Gender {
  MALE
  FEMALE
}

enum MarriageStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum ContractStatus {
  DRAFT
  PENDING
  APPROVED
  SIGNED
  TERMINATED
  EXPIRED
}

enum OrderStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentType {
  CLIENT_FEE
  SCHOOL_COMMISSION
  PARTNER_FEE
  OTHER_INCOME
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  WECHAT
  ALIPAY
  CREDIT_CARD
}

enum Currency {
  CNY
  USD
  GBP
  AUD
  CAD
  SGD
  MYR
}

enum CommissionStatus {
  PENDING
  RELEASED
  ADJUSTED
  CANCELLED
}

enum ApplicationStatus {
  PREPARING
  SUBMITTED
  REVIEWING
  OFFER
  REJECTED
  DEFERRED
  ACCEPTED
}

enum OfferStatus {
  RECEIVED
  ACCEPTED
  DECLINED
  EXPIRED
}

enum VisaStatus {
  NOT_STARTED
  PREPARING
  SUBMITTED
  APPROVED
  REJECTED
  APPEALING
}

enum VisitStage {
  AFTER_SIGN
  APPLICATION
  OFFER_STAGE
  VISA_STAGE
  AFTER_ENROLL
  LONG_TERM
}

enum TriggerType {
  SCHEDULED
  EVENT
}

enum PlanStatus {
  PENDING
  COMPLETED
  SKIPPED
}

enum VisitType {
  PHONE
  WECHAT
  FACE_TO_FACE
  VIDEO
}

enum Mood {
  SATISFIED
  NEUTRAL
  ANXIOUS
  DISSATISFIED
}

enum UpsellType {
  UPGRADE
  RENEWAL
  FAMILY
  WORK_VISA
  IMMIGRATION
  OTHER_SERVICE
}

enum LifecycleEventType {
  SIGNED
  APPLIED
  OFFER_RECEIVED
  OFFER_ACCEPTED
  VISA_SUBMITTED
  VISA_GRANTED
  ENROLLED
  GRADUATED
  RENEWAL
  UPSELL
  REFERRAL
  COMPLAINT
  REFUND
}

enum AppealStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WorkflowNodeType {
  START
  TASK
  APPROVAL
  CONDITION
  END
}

enum WorkflowInstanceStatus {
  RUNNING
  COMPLETED
  TERMINATED
  SUSPENDED
}

enum ReimbursementStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

model Tenant {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  slug      String   @unique @db.VarChar(50)
  logo      String?  @db.Text
  status    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users               User[]
  roles               Role[]
  dicts               Dict[]
  configs             SystemConfig[]
  depts               Department[]
  positions           Position[]
  employees           Employee[]
  students            Student[]
  contracts           Contract[]
  orders              Order[]
  applications        Application[]
  payments            Payment[]
  costs               Cost[]
  commissions         Commission[]
  salaries            Salary[]
  reimbursements      Reimbursement[]
  profitReports       ProfitReport[]
  workflows           Workflow[]
  files               File[]
  rentalOrders        RentalOrder[]
  overseasServices    OverseasService[]
  partners            Partner[]
  sites               Site[]
  mediaAccounts       MediaAccount[]
  auditLogs           AuditLog[]
  businessLines       BusinessLine[]
  commissionRules     CommissionRule[]
  countries           Country[]
  institutions        Institution[]
  majors              Major[]
  products            Product[]
  productPackages     ProductPackage[]
  securityPolicies    SecurityPolicy[]
  approvalFlows       ApprovalFlow[]
  approvalRecords     ApprovalRecord[]
  satisfactionSurveys SatisfactionSurvey[]
  serviceVisits       ServiceVisit[]
  complaints          Complaint[]
  referrals           Referral[]
  riskRules           RiskRule[]
  riskRecords         RiskRecord[]
  riskNotifications   RiskNotification[]
  operationLogs       OperationLog[]
  loginLogs           LoginLog[]

  @@map("tenants")
}

model User {
  id             Int       @id @default(autoincrement())
  tenantId       Int       @map("tenant_id")
  username       String    @unique @db.VarChar(50)
  passwordHash   String    @map("password_hash") @db.VarChar(255)
  realName       String?   @map("real_name") @db.VarChar(50)
  email          String?   @db.VarChar(100)
  phone          String?   @db.VarChar(20)
  avatar         String?   @db.Text
  dingtalkUserId String?   @map("dingtalk_user_id") @db.VarChar(100)
  isActive       Boolean   @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  employee         Employee?
  userRoles        UserRole[]
  userDepts        UserDepartment[]
  notifications    Notification[]
  createdAudit     AuditLog[]       @relation("audit_creator")
  createdOperation OperationLog[]   @relation("operation_creator")
  createdLogin     LoginLog[]       @relation("login_creator")
  visitPlans       VisitPlan[]      @relation("plan_assignee")
  visitRecords     VisitRecord[]    @relation("visit_visitor")
  assignedStudents Student[]        @relation("student_assignee")
  assignedLeads    Lead[]           @relation("lead_assignee")
  followUps        FollowUp[]
  assignedOrders   Order[]          @relation("order_assignee")
  reimbursements   Reimbursement[]
  uploadedFiles    File[]

  @@index([tenantId])
  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @map("tenant_id")
  name        String   @db.VarChar(50)
  code        String   @unique @db.VarChar(50)
  description String?  @db.Text
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant          Tenant                     @relation(fields: [tenantId], references: [id])
  userRoles       UserRole[]
  roleMenus       RoleMenu[]
  rolePermissions RolePermission[]
  roleFieldGroups RoleFieldGroupPermission[]

  @@index([tenantId])
  @@map("roles")
}

model Menu {
  id        Int      @id @default(autoincrement())
  parentId  Int?     @map("parent_id")
  name      String   @db.VarChar(50)
  code      String   @unique @db.VarChar(100)
  path      String?  @db.VarChar(200)
  icon      String?  @db.VarChar(50)
  sort      Int      @default(0)
  type      String   @default("menu") @db.VarChar(20)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  parent    Menu?      @relation("menu_children", fields: [parentId], references: [id])
  children  Menu[]     @relation("menu_children")
  roleMenus RoleMenu[]

  @@map("menus")
}

model Permission {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(50)
  code      String   @unique @db.VarChar(100)
  groupName String?  @map("group_name") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RoleMenu {
  id     Int @id @default(autoincrement())
  roleId Int @map("role_id")
  menuId Int @map("menu_id")

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@unique([roleId, menuId])
  @@map("role_menus")
}

model RolePermission {
  id           Int @id @default(autoincrement())
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RoleFieldGroupPermission {
  id         Int    @id @default(autoincrement())
  roleId     Int    @map("role_id")
  tableName  String @map("table_name") @db.VarChar(50)
  fieldGroup String @map("field_group") @db.VarChar(50)
  access     String @default("visible") @db.VarChar(20)

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, tableName, fieldGroup])
  @@map("role_field_group_permissions")
}

model UserRole {
  id     Int @id @default(autoincrement())
  userId Int @map("user_id")
  roleId Int @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Dict {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @map("tenant_id")
  groupName String   @map("group_name") @db.VarChar(50)
  dictKey   String   @map("dict_key") @db.VarChar(50)
  dictValue String   @map("dict_value") @db.VarChar(200)
  sort      Int      @default(0)
  isEnabled Boolean  @default(true) @map("is_enabled")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, groupName, dictKey])
  @@index([tenantId, groupName])
  @@map("dicts")
}

model SystemConfig {
  id          Int      @id @default(autoincrement())
  tenantId    Int      @map("tenant_id")
  configKey   String   @map("config_key") @db.VarChar(100)
  configValue Json     @map("config_value")
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, configKey])
  @@map("system_configs")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  tenantId   Int      @map("tenant_id")
  userId     Int      @map("user_id")
  action     String   @db.VarChar(50)
  tableName  String?  @map("table_name") @db.VarChar(50)
  recordId   Int?     @map("record_id")
  beforeData Json?    @map("before_data")
  afterData  Json?    @map("after_data")
  ipAddress  String?  @map("ip_address") @db.VarChar(50)
  userAgent  String?  @map("user_agent") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation("audit_creator", fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tableName, recordId])
  @@index([createdAt])
  @@map("audit_logs")
}

model OperationLog {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @map("tenant_id")
  userId    Int      @map("user_id")
  module    String   @db.VarChar(50) // 业务模块，如 students/contracts/products
  action    String   @db.VarChar(50) // CREATE/UPDATE/DELETE/EXPORT/IMPORT/LOGIN...
  target    String?  @db.VarChar(200) // 操作对象描述，如 "学生:张三(id=12)"
  detail    Json? // 操作补充说明
  ipAddress String?  @map("ip_address") @db.VarChar(50)
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation("operation_creator", fields: [userId], references: [id])

  @@index([tenantId])
  @@index([module])
  @@index([action])
  @@index([createdAt])
  @@map("operation_logs")
}

model LoginLog {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @map("tenant_id")
  userId    Int?     @map("user_id") // 登录失败可能无对应用户
  username  String?  @db.VarChar(100)
  status    String   @db.VarChar(20) // SUCCESS / FAILED
  reason    String?  @db.VarChar(200) // 失败原因
  ipAddress String?  @map("ip_address") @db.VarChar(50)
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation("login_creator", fields: [userId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("login_logs")
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  title     String    @db.VarChar(200)
  content   String?   @db.Text
  type      String    @default("info") @db.VarChar(20)
  isRead    Boolean   @default(false) @map("is_read")
  link      String?   @db.VarChar(500)
  createdAt DateTime  @default(now()) @map("created_at")
  readAt    DateTime? @map("read_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model Department {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @map("tenant_id")
  parentId  Int?     @map("parent_id")
  name      String   @db.VarChar(100)
  code      String   @db.VarChar(50)
  sort      Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  parent    Department?      @relation("dept_children", fields: [parentId], references: [id])
  children  Department[]     @relation("dept_children")
  positions Position[]
  userDepts UserDepartment[]

  @@index([tenantId])
  @@map("departments")
}

model Position {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @map("tenant_id")
  deptId    Int      @map("dept_id")
  name      String   @db.VarChar(100)
  code      String   @db.VarChar(50)
  sort      Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  department Department @relation(fields: [deptId], references: [id])
  employees  Employee[]

  @@index([tenantId, deptId])
  @@map("positions")
}

model Employee {
  id         Int       @id @default(autoincrement())
  tenantId   Int       @map("tenant_id")
  userId     Int?      @unique @map("user_id")
  positionId Int?      @map("position_id")
  name       String    @db.VarChar(50)
  employeeNo String?   @map("employee_no") @db.VarChar(50)
  gender     Gender?
  phone      String?   @db.VarChar(20)
  email      String?   @db.VarChar(100)
  dingtalkId String?   @map("dingtalk_id") @db.VarChar(100)
  entryDate  DateTime? @map("entry_date")
  leaveDate  DateTime? @map("leave_date")
  status     String    @default("active") @db.VarChar(20)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
  position Position? @relation(fields: [positionId], references: [id])
  salaries Salary[]

  @@index([tenantId])
  @@map("employees")
}

model UserDepartment {
  id     Int @id @default(autoincrement())
  userId Int @map("user_id")
  deptId Int @map("dept_id")

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  dept Department @relation(fields: [deptId], references: [id], onDelete: Cascade)

  @@unique([userId, deptId])
  @@map("user_departments")
}

model BusinessLine {
  id         Int      @id @default(autoincrement())
  tenantId   Int      @map("tenant_id")
  name       String   @db.VarChar(100)
  code       String   @unique @db.VarChar(50)
  formSchema Json?    @map("form_schema")
  status     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  contracts Contract[]
  products  Product[]

  @@index([tenantId])
  @@map("business_lines")
}

model ServiceProcess {
  id             Int      @id @default(autoincrement())
  tenantId       Int      @map("tenant_id")
  name           String   @db.VarChar(100)
  stage          String   @db.VarChar(50)
  sort           Int      @default(0)
  requiredFields Json?    @map("required_fields")
  description    String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("service_processes")
}

model CommissionRule {
  id            Int       @id @default(autoincrement())
  tenantId      Int       @map("tenant_id")
  name          String    @db.VarChar(100)
  version       Int       @default(1)
  ruleType      String    @map("rule_type") @db.VarChar(30)
  config        Json
  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  status        Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  commissions Commission[]

  @@index([tenantId, status])
  @@map("commission_rules")
}

model Student {
  id               Int       @id @default(autoincrement())
  tenantId         Int       @map("tenant_id")
  name             String    @db.VarChar(50)
  gender           Gender?
  birthDate        DateTime? @map("birth_date")
  phone            String?   @db.VarChar(20)
  wechat           String?   @db.VarChar(50)
  email            String?   @db.VarChar(100)
  idNumber         String?   @map("id_number") @db.VarChar(30)
  passportNo       String?   @map("passport_no") @db.VarChar(30)
  nationality      String?   @db.VarChar(50)
  currentSchool    String?   @map("current_school") @db.VarChar(200)
  currentMajor     String?   @map("current_major") @db.VarChar(200)
  education        String?   @db.VarChar(50)
  gpa              Decimal?  @db.Decimal(4, 2)
  languageScore    Json?     @map("language_score")
  targetCountry    String?   @map("target_country") @db.VarChar(50)
  targetDegree     String?   @map("target_degree") @db.VarChar(50)
  targetMajor      String?   @map("target_major") @db.VarChar(200)
  budget           Decimal?  @db.Decimal(12, 2)
  emergencyContact String?   @map("emergency_contact") @db.VarChar(100)
  emergencyPhone   String?   @map("emergency_phone") @db.VarChar(20)
  remark           String?   @db.Text
  source           String?
  referrerId       Int?      @map("referrer_id")
  assignedToId     Int?      @map("assigned_to_id")
  currentStatus    String?   @map("current_status") @db.VarChar(50)
  extData          Json?     @map("ext_data")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  tenant              Tenant                  @relation(fields: [tenantId], references: [id])
  assignedTo          User?                   @relation("student_assignee", fields: [assignedToId], references: [id])
  leads               Lead[]
  followUps           FollowUp[]
  contracts           Contract[]
  orders              Order[]
  applications        Application[]
  visitPlans          VisitPlan[]
  visitRecords        VisitRecord[]
  lifecycleEvents     StudentLifecycleEvent[]
  payments            Payment[]
  commissions         Commission[]
  rentalOrders        RentalOrder[]
  overseasServices    OverseasService[]
  costs               Cost[]
  satisfactionSurveys SatisfactionSurvey[]
  serviceVisits       ServiceVisit[]
  complaints          Complaint[]
  referralsMade       Referral[]              @relation("ReferralsByStudent")
  referralNew         Referral[]              @relation("ReferralNewStudent")
  riskRecords         RiskRecord[]

  @@index([tenantId])
  @@index([assignedToId])
  @@index([phone])
  @@index([wechat])
  @@map("students")
}

model Lead {
  id             Int        @id @default(autoincrement())
  tenantId       Int        @map("tenant_id")
  studentId      Int?       @map("student_id")
  name           String     @db.VarChar(50)
  phone          String     @db.VarChar(20)
  wechat         String?    @db.VarChar(50)
  source         String
  sourceDetail   String?    @map("source_detail") @db.VarChar(500)
  status         LeadStatus @default(NEW)
  assignedToId   Int        @map("assigned_to_id")
  intentionLevel String?    @map("intention_level") @db.VarChar(20)
  targetCountry  String?    @map("target_country") @db.VarChar(50)
  targetDegree   String?    @map("target_degree") @db.VarChar(50)
  budget         Decimal?   @db.Decimal(12, 2)
  remark         String?    @db.Text
  extData        Json?      @map("ext_data")
  lastFollowUpAt DateTime?  @map("last_follow_up_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  student      Student?          @relation(fields: [studentId], references: [id])
  assignedTo   User              @relation("lead_assignee", fields: [assignedToId], references: [id])
  followUps    FollowUp[]
  transferLogs LeadTransferLog[]
  appeals      LeadAppeal[]

  @@index([tenantId, assignedToId])
  @@index([status])
  @@map("leads")
}

model LeadTransferLog {
  id         Int      @id @default(autoincrement())
  leadId     Int      @map("lead_id")
  fromUserId Int      @map("from_user_id")
  toUserId   Int      @map("to_user_id")
  reason     String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_transfer_logs")
}

model LeadAppeal {
  id          Int          @id @default(autoincrement())
  leadId      Int          @map("lead_id")
  appellantId Int          @map("appellant_id")
  reason      String       @db.Text
  evidence    String?      @db.Text
  status      AppealStatus @default(PENDING)
  reviewedBy  Int?         @map("reviewed_by")
  reviewNote  String?      @map("review_note") @db.Text
  reviewedAt  DateTime?    @map("reviewed_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_appeals")
}

model FollowUp {
  id             Int       @id @default(autoincrement())
  studentId      Int       @map("student_id")
  leadId         Int?      @map("lead_id")
  userId         Int       @map("user_id")
  type           String    @default("phone") @db.VarChar(20)
  content        String    @db.Text
  nextPlan       String?   @map("next_plan") @db.Text
  nextFollowUpAt DateTime? @map("next_follow_up_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id])
  lead    Lead?   @relation(fields: [leadId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([studentId])
  @@index([leadId])
  @@map("follow_ups")
}

model Contract {
  id              Int            @id @default(autoincrement())
  tenantId        Int            @map("tenant_id")
  studentId       Int            @map("student_id")
  contractNo      String         @unique @map("contract_no") @db.VarChar(50)
  businessLineId  Int?           @map("business_line_id")
  signDate        DateTime       @map("sign_date")
